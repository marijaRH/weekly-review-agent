# Copy to .env or export these in the shell that runs the digest (e.g. cron).
# Required
QUANTUM_DIGEST_RECIPIENT=your.email@example.com

# Optional: sender address (defaults to recipient)
# QUANTUM_DIGEST_SENDER=your.email@example.com

# Option A: Gmail (recommended). Enable 2FA, then create an App Password:
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-16-char-app-password

# Option B: Custom SMTP (e.g. SendGrid, Mailgun, Outlook)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
