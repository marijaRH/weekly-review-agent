# AI Office Hours — weekly sync of meeting recordings/transcripts to a Drive folder
# Copy to ai-office-hours-sync.env and set credentials. Run: ./scripts/run-ai-office-hours-sync.sh
# Cron (e.g. Mondays 9 AM CET): 0 8 * * 1 ... run-ai-office-hours-sync.sh

# Google Service Account JSON (required). Either:
# 1) Path to the JSON key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
# 2) Or the JSON content as a single line (e.g. in GitHub Secrets as GCP_SA_KEY):
# GCP_SA_KEY='{"type":"service_account",...}'

# Calendar to search (default: primary). Use your email if using a service account
# and you've shared the calendar with the SA.
# AI_OFFICE_HOURS_CALENDAR_ID=primary
# AI_OFFICE_HOURS_CALENDAR_ID=your.email@example.com

# Drive folder where new recordings will be copied (default already set in script)
# AI_OFFICE_HOURS_TARGET_FOLDER_ID=1qWWkHcqefAS5RVCCUazcEjsRHesWfVo2
