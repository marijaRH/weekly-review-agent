# Second digest: different topic, different recipient.
# Copy to e.g. digest-ai.env or digest-opensource.env and fill in.
# Run with: ./scripts/run-quantum-digest.sh scripts/digest-ai.env
# Add a second cron line to send daily (same or different time).

QUANTUM_DIGEST_RECIPIENT=other.person@example.com

# Topic: only articles whose title/summary contain ANY of these (comma-separated).
# Examples: "ai,machine learning" or "red hat,openshift,rhel" or "security,cyber"
DIGEST_TOPIC_KEYWORDS=ai,machine learning,llm

# Optional: subject line (default is "Quantum Digest")
DIGEST_NAME=AI Digest

# Optional: use different RSS feeds (comma-separated URLs). If unset, uses default quantum + Red Hat feeds.
# DIGEST_FEEDS=https://www.redhat.com/en/rss/blog,https://feeds.feedburner.com/SomeOtherFeed

# Same Gmail App Password as main digest (or another account)
GMAIL_APP_PASSWORD="your-16-char-app-password"
